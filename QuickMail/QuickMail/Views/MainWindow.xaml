<Window x:Class="QuickMail.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:QuickMail.Views"
        xmlns:models="clr-namespace:QuickMail.Models"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="QuickMail"
        Height="650" Width="1000"
        MinHeight="400" MinWidth="700">

    <Window.Resources>
        <local:BoolToFontWeightConverter x:Key="BoolToWeightConverter"/>
        <BooleanToVisibilityConverter    x:Key="BoolToVisibilityConverter"/>
        <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Window.Resources>

    <Window.InputBindings>
        <!-- Ctrl+N, F5, Ctrl+M, Ctrl+Shift+E use valid KeyGestures (modifier or function key). -->
        <!-- R, Shift+R, F have no modifier so WPF KeyGesture rejects them; handled in PreviewKeyDown. -->
        <KeyBinding Key="N"  Modifiers="Ctrl"       Command="{Binding NewMessageCommand}"       />
        <KeyBinding Key="F5"                        Command="{Binding RefreshCommand}"          />
        <KeyBinding Key="M"  Modifiers="Ctrl"       Command="{Binding LoadMoreMessagesCommand}" />
        <KeyBinding Key="E"  Modifiers="Ctrl+Shift" Command="{Binding EmptyTrashCommand}"       />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Toolbar -->
            <RowDefinition Height="*"/>     <!-- Content -->
            <RowDefinition Height="Auto"/>  <!-- Status bar -->
        </Grid.RowDefinitions>

        <!-- ── Toolbar — one tab stop; Arrow keys navigate between buttons ── -->
        <ToolBar x:Name="MainToolbar"
                 Grid.Row="0"
                 AutomationProperties.Name="Main toolbar"
                 KeyboardNavigation.DirectionalNavigation="Cycle"
                 PreviewKeyDown="Toolbar_PreviewKeyDown">
            <Button x:Name="ToolbarFirstButton"
                    Style="{StaticResource ToolbarButton}"
                    Command="{Binding NewMessageCommand}"
                    AutomationProperties.Name="New Message (Ctrl+N)"
                    ToolTip="New Message (Ctrl+N)"
                    Content="_New"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding ReplyCommand}"
                    AutomationProperties.Name="Reply (Ctrl+R)"
                    ToolTip="Reply (Ctrl+R)"
                    Content="_Reply"/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding ReplyAllCommand}"
                    AutomationProperties.Name="Reply All (Ctrl+Shift+R)"
                    ToolTip="Reply All (Ctrl+Shift+R)"
                    Content="Reply _All"/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding ForwardCommand}"
                    AutomationProperties.Name="Forward (Ctrl+F)"
                    ToolTip="Forward (Ctrl+F)"
                    Content="_Forward"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding DeleteMessageCommand}"
                    AutomationProperties.Name="Delete message (Delete key)"
                    ToolTip="Delete (Del)"
                    Content="_Delete"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding RefreshCommand}"
                    AutomationProperties.Name="Refresh (F5)"
                    ToolTip="Refresh (F5)"
                    Content="Refres_h"/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding LoadMoreMessagesCommand}"
                    AutomationProperties.Name="Load more messages (Ctrl+M)"
                    ToolTip="Load 100 more messages (Ctrl+M)"
                    Content="Load _More"/>
            <Separator/>
            <ToggleButton Style="{StaticResource ToolbarToggleButton}"
                          IsChecked="{Binding IsConversationView, Mode=TwoWay}"
                          AutomationProperties.Name="Conversation view (Ctrl+Shift+C)"
                          ToolTip="Group messages by subject (Ctrl+Shift+C)"
                          Content="Conver_sation"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding EmptyTrashCommand}"
                    AutomationProperties.Name="Empty Trash (Ctrl+Shift+E)"
                    ToolTip="Empty Trash (Ctrl+Shift+E)"
                    Content="Empty _Trash"/>
            <Separator/>
            <Button Style="{StaticResource ToolbarButton}"
                    Command="{Binding ManageAccountsCommand}"
                    AutomationProperties.Name="Manage email accounts"
                    ToolTip="Manage email accounts"
                    Content="Accoun_ts"/>
        </ToolBar>

        <!-- ── Three-pane layout (Outlook-style): Accounts+Folders left | Messages right ── -->
        <!--  Tab loop: AccountList(1) → FolderList(2) → MessageList(3) → Toolbar → StatusBar → wrap -->
        <!--  Arrow keys navigate within the focused pane (TabNavigation=Once on each)      -->
        <!--  Enter triggers action; focus never changes unless user does it                 -->
        <!--  Ctrl+0 = toolbar | Ctrl+1/2/3 = jump directly to any pane                    -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200" MinWidth="120"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- Left pane: Accounts on top, Folders below -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"  MinHeight="60"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="2*" MinHeight="80"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Accounts" FontWeight="SemiBold" Padding="6,4"
                           Focusable="False"
                           Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

                <ListBox Grid.Row="1"
                         x:Name="AccountList"
                         AutomationProperties.Name="Email accounts. Arrow keys to navigate, Enter to connect."
                         ItemsSource="{Binding Accounts}"
                         SelectedItem="{Binding SelectedAccount, Mode=TwoWay}"
                         DisplayMemberPath="DisplayName"
                         BorderThickness="0,0,1,0"
                         TabIndex="1"
                         KeyboardNavigation.TabNavigation="Once"
                         GotKeyboardFocus="List_GotKeyboardFocus"
                         PreviewKeyDown="AccountList_PreviewKeyDown"/>

                <TextBlock Grid.Row="2" Text="Folders" FontWeight="SemiBold" Padding="6,4"
                           Focusable="False"
                           Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"/>

                <!-- True TreeView so screen readers announce level, expanded/collapsed state correctly. -->
                <TreeView Grid.Row="3"
                          x:Name="FolderList"
                          AutomationProperties.Name="Folders. Arrow keys to navigate and expand, Enter to load messages."
                          ItemsSource="{Binding FolderTree}"
                          BorderThickness="0,0,1,0"
                          TabIndex="2"
                          KeyboardNavigation.TabNavigation="Once"
                          PreviewKeyDown="FolderList_PreviewKeyDown">
                    <TreeView.Resources>
                        <HierarchicalDataTemplate DataType="{x:Type models:FolderTreeNode}"
                                                  ItemsSource="{Binding Children}">
                            <TextBlock TextTrimming="CharacterEllipsis">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Label}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                                <Setter Property="FontWeight" Value="SemiBold"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </HierarchicalDataTemplate>
                    </TreeView.Resources>
                    <TreeView.ItemContainerStyle>
                        <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                            <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                            <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}"/>
                        </Style>
                    </TreeView.ItemContainerStyle>
                </TreeView>
            </Grid>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          IsTabStop="False"
                          AutomationProperties.Name="Resize left and right panes"/>

            <!-- Right pane: messages + body (body docked to bottom, hidden until Enter on a message) -->
            <DockPanel Grid.Column="2">

                <!-- Body pane — hidden until IsMessageOpen; Escape returns to MessageList -->
                <Border DockPanel.Dock="Bottom"
                        BorderThickness="0,1,0,0"
                        BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                        MinHeight="200"
                        Visibility="{Binding IsMessageOpen, Converter={StaticResource BoolToVisibilityConverter}}">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top" Margin="8,6,8,0">
                            <TextBlock Text="{Binding MessageDetail.Subject, FallbackValue=''}"
                                       FontSize="13" FontWeight="SemiBold" TextWrapping="Wrap"
                                       AutomationProperties.Name="{Binding MessageDetail.Subject, FallbackValue=''}"/>
                            <TextBlock Text="{Binding MessageDetail.From, StringFormat='From: {0}', FallbackValue=''}"
                                       Margin="0,2,0,0"/>
                            <TextBlock Text="{Binding MessageDetail.To, StringFormat='To: {0}', FallbackValue=''}"/>
                            <TextBlock Text="{Binding MessageDetail.Cc, StringFormat='Cc: {0}', FallbackValue=''}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MessageDetail.Cc}" Value="">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding MessageDetail.Cc}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="{Binding MessageDetail.Date, StringFormat='Date: {0:f}', FallbackValue=''}"/>
                            <Separator Margin="0,4,0,0"/>
                        </StackPanel>
                        <!-- WebView2: real browser, proper arrow-key caret nav, screen-reader virtual cursor -->
                        <wv2:WebView2 x:Name="MessageBody"
                                      AutomationProperties.Name="Message body. Press Escape to return to message list."
                                      KeyboardNavigation.IsTabStop="False"
                                      MinHeight="80"/>
                    </DockPanel>
                </Border>

                <!-- Message list — fills all remaining space; body docked above takes its share -->
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top"
                               Text="{Binding SelectedFolder.DisplayName, FallbackValue='No folder selected'}"
                               FontWeight="SemiBold" Padding="6,4"
                               Focusable="False"
                               Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                               AutomationProperties.Name="Current folder"/>

                    <TextBlock DockPanel.Dock="Top"
                               Text="No messages"
                               AutomationProperties.LiveSetting="Polite"
                               HorizontalAlignment="Center" Margin="0,20">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Messages.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- Standard list view and conversation tree occupy the same space;
                         only one is visible at a time based on IsConversationView. -->
                    <Grid>
                    <ListView x:Name="MessageList"
                              AutomationProperties.Name="Messages"
                              AutomationProperties.LiveSetting="Polite"
                              Visibility="{Binding IsConversationView, Converter={StaticResource InverseBoolToVisibilityConverter}}"
                              ItemsSource="{Binding Messages}"
                              SelectedItem="{Binding SelectedMessage, Mode=TwoWay}"
                              SelectionMode="Extended"
                              BorderThickness="0"
                              TabIndex="3"
                              KeyboardNavigation.TabNavigation="Once"
                              GotKeyboardFocus="List_GotKeyboardFocus"
                              PreviewKeyDown="MessageList_PreviewKeyDown"
                              MouseLeftButtonUp="MessageList_MouseLeftButtonUp">
                        <ListView.Resources>
                            <!-- Column headers are mouse-clickable but not keyboard tab stops -->
                            <Style TargetType="GridViewColumnHeader">
                                <Setter Property="Focusable" Value="False"/>
                            </Style>
                        </ListView.Resources>
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Width="180">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="From"
                                                              AutomationProperties.IsColumnHeader="True"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding From}"
                                                       FontWeight="{Binding IsRead, Converter={StaticResource BoolToWeightConverter}}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="Auto">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="Subject"
                                                              AutomationProperties.IsColumnHeader="True"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Subject}"
                                                       FontWeight="{Binding IsRead, Converter={StaticResource BoolToWeightConverter}}"
                                                       TextTrimming="CharacterEllipsis"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Width="80">
                                    <GridViewColumn.Header>
                                        <GridViewColumnHeader Content="Date"
                                                              AutomationProperties.IsColumnHeader="True"/>
                                    </GridViewColumn.Header>
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding DateDisplay}" TextAlignment="Right"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                <Setter Property="AutomationProperties.Name">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="{}{0}. {1}. {2}. {3}.">
                                            <Binding Path="From"/>
                                            <Binding Path="Subject"/>
                                            <Binding Path="Preview"/>
                                            <Binding Path="DateDisplay"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>

                    <!-- Conversation tree view: one root node per subject group, children are individual messages. -->
                    <TreeView x:Name="ConversationTree"
                              AutomationProperties.Name="Messages"
                              AutomationProperties.LiveSetting="Polite"
                              Visibility="{Binding IsConversationView, Converter={StaticResource BoolToVisibilityConverter}}"
                              ItemsSource="{Binding Conversations}"
                              BorderThickness="0"
                              TabIndex="3"
                              KeyboardNavigation.TabNavigation="Once"
                              VirtualizingPanel.IsVirtualizing="True"
                              VirtualizingPanel.VirtualizationMode="Recycling"
                              ScrollViewer.CanContentScroll="True"
                              GotKeyboardFocus="ConversationTree_GotKeyboardFocus"
                              SelectedItemChanged="ConversationTree_SelectedItemChanged"
                              PreviewKeyDown="ConversationTree_PreviewKeyDown">
                        <TreeView.Resources>
                            <!-- Style for level-2 message rows (children of a conversation node) -->
                            <Style x:Key="MessageTreeItemStyle" TargetType="TreeViewItem"
                                   BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="AutomationProperties.Name">
                                    <Setter.Value>
                                        <MultiBinding StringFormat="{}{0}. {1}. {2}. {3}.">
                                            <Binding Path="From"/>
                                            <Binding Path="Subject"/>
                                            <Binding Path="Preview"/>
                                            <Binding Path="DateDisplay"/>
                                        </MultiBinding>
                                    </Setter.Value>
                                </Setter>
                            </Style>

                            <!-- Level 1: conversation group header with subject + count + preview -->
                            <HierarchicalDataTemplate DataType="{x:Type models:ConversationGroup}"
                                                      ItemsSource="{Binding Messages}"
                                                      ItemContainerStyle="{StaticResource MessageTreeItemStyle}">
                                <StackPanel>
                                    <TextBlock TextTrimming="CharacterEllipsis"
                                               FontWeight="{Binding HasUnread, Converter={StaticResource BoolToWeightConverter}}">
                                        <Run Text="{Binding Subject, Mode=OneWay}"/>
                                        <Run Text=" "/>
                                        <Run Text="{Binding Count, StringFormat=({0}), Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock Text="{Binding LastSenderName}"
                                               FontSize="11" Opacity="0.85"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LastSenderName}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <TextBlock Text="{Binding Preview}"
                                               FontSize="11" Opacity="0.7"
                                               TextTrimming="CharacterEllipsis">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Preview}" Value="">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </HierarchicalDataTemplate>

                            <!-- Level 2: individual message row matching the ListView column layout -->
                            <DataTemplate DataType="{x:Type models:MailMessageSummary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="180"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding From}"
                                               FontWeight="{Binding IsRead, Converter={StaticResource BoolToWeightConverter}}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Subject}"
                                               FontWeight="{Binding IsRead, Converter={StaticResource BoolToWeightConverter}}"
                                               TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Grid.Column="2" Text="{Binding DateDisplay}"
                                               TextAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </TreeView.Resources>
                        <TreeView.ItemContainerStyle>
                            <!-- Style for root-level conversation group nodes: starts collapsed -->
                            <Style TargetType="TreeViewItem" BasedOn="{StaticResource {x:Type TreeViewItem}}">
                                <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                <Setter Property="AutomationProperties.Name" Value="{Binding AutomationName}"/>
                            </Style>
                        </TreeView.ItemContainerStyle>
                    </TreeView>

                    </Grid>
                </DockPanel>

            </DockPanel>
        </Grid>

        <!-- ── Status bar ── -->
        <StatusBar Grid.Row="2">
            <StatusBarItem>
                <TextBlock Text="{Binding StatusText}"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.Name="Status"/>
            </StatusBarItem>
            <StatusBarItem HorizontalAlignment="Right">
                <ProgressBar Width="80" Height="14"
                             IsIndeterminate="True"
                             Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                             AutomationProperties.Name="Loading in progress"/>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>
